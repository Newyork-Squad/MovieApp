<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/background_screen">

    <data>

        <variable
            name="viewModel"
            type="com.karrar.movieapp.ui.login.LoginViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.login.LoginFragment">

        <!-- Logo -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="60dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/cine_verse_logo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Welcome -->
        <TextView
            android:id="@+id/welcomeText"
            style="@style/Title.LG"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/welcome_back_to_cineverse"
            android:textColor="@color/shade_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/logo" />

        <!-- Username Label -->
        <TextView
            android:id="@+id/usernameLabel"
            style="@style/Body_MD.Regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="48dp"
            android:text="@string/username"
            android:textColor="@color/shade_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/welcomeText" />

        <!-- Username -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/userNameLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="8dp"
            android:hint="@string/enter_your_username"

            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="@dimen/radius_lg"
            app:boxCornerRadiusBottomStart="@dimen/radius_lg"
            app:boxCornerRadiusTopEnd="@dimen/radius_lg"
            app:boxCornerRadiusTopStart="@dimen/radius_lg"

            app:boxStrokeColor="@color/text_input_stroke_colors"
            app:boxStrokeErrorColor="@color/primary_red"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="1dp"
            app:error="@{viewModel.loginUIState.userNameHelperText}"
            app:errorEnabled="true"
            app:errorIconDrawable="@drawable/outline_danger_triangle"
            app:errorTextColor="@color/primary_red"
            app:helperTextTextColor="@color/primary_red"

            app:hintTextColor="@color/shade_tertiary"
            app:indicatorColor="@color/brand_primary"
            app:layout_constraintTop_toBottomOf="@id/usernameLabel"
            app:startIconDrawable="@drawable/outline_user"
            app:startIconTint="@color/shade_tertiary">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:afterTextChanged="@{(text) -> viewModel.onUserNameInputChange(text)}"
                android:inputType="textPersonName"
                android:textColor="@color/shade_primary"
                android:textColorHint="@color/shade_secondary" />
        </com.google.android.material.textfield.TextInputLayout>


        <TextView
            android:id="@+id/passwordLabel"
            style="@style/Body_MD.Regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/password"
            android:layout_marginTop="8dp"
            android:textColor="@color/shade_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/userNameLayout" />

        <!-- Password -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/passwordLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="16dp"
            android:hint="@string/enter_your_password"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="@dimen/radius_lg"
            app:boxCornerRadiusBottomStart="@dimen/radius_lg"
            app:boxCornerRadiusTopEnd="@dimen/radius_lg"
            app:boxCornerRadiusTopStart="@dimen/radius_lg"
            app:boxStrokeColor="@color/text_input_stroke_colors"
            app:boxStrokeErrorColor="@color/primary_red"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="1dp"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/shade_tertiary"
            app:error="@{viewModel.loginUIState.passwordHelperText}"
            app:errorEnabled="true"
            app:errorIconDrawable="@drawable/outline_danger_triangle"
            app:errorTextColor="@color/primary_red"
            app:helperTextTextColor="@color/primary_red"
            app:hintTextColor="@color/shade_tertiary"
            app:indicatorColor="@color/brand_primary"
            app:layout_constraintTop_toBottomOf="@id/passwordLabel"
            app:onPasswordToggle="@{() -> viewModel.togglePasswordVisibility()}"
            app:passwordVisible="@{viewModel.loginUIState.passwordVisible}"
            app:startIconDrawable="@drawable/outline_lock"
            app:startIconTint="@color/shade_tertiary">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:afterTextChanged="@{(text) -> viewModel.onPasswordInputChange(text)}"
                android:inputType="textPassword"
                android:textColor="@color/shade_primary"
                android:textColorHint="@color/shade_secondary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Forgot password -->
        <TextView
            android:id="@+id/forgotPassword"
            style="@style/Body_MD.Regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/forgot_password"
            android:textColor="@color/shade_secondary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@id/passwordLayout"
            app:layout_constraintTop_toBottomOf="@id/passwordLayout" />


        <View
            android:id="@+id/dividerForgotPassword"
            android:layout_width="0dp"
            android:layout_height="0.05dp"
            android:background="@color/shade_secondary"
            app:layout_constraintEnd_toEndOf="@id/forgotPassword"
            app:layout_constraintStart_toStartOf="@id/forgotPassword"
            app:layout_constraintTop_toBottomOf="@id/forgotPassword" />


        <!-- Login button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/loginButton"
            style="@style/Body_MD"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:elevation="0dp"
            android:enabled="@{viewModel.loginUIState.validForm}"
            android:onClick="@{()->viewModel.onClickLogin()}"
            android:text="@string/login"
            android:textAllCaps="false"
            android:textColor="@color/button_onPrimary"
            app:backgroundTint="@color/button_login_background"
            app:cornerRadius="@dimen/radius_lg"
            app:hideIfTrue="@{viewModel.loginUIState.loading}"
            app:layout_constraintTop_toBottomOf="@id/forgotPassword" />

        <!-- Loading indicator -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:indeterminate="true"
            app:indicatorColor="@color/background_card"
            app:isVisible="@{viewModel.loginUIState.loading}"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/forgotPassword" />


        <!-- Join as Guest -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/guestButton"
            style="@style/Body_MD.Medium"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            android:elevation="0dp"
            android:text="@string/join_as_guest"
            android:textAllCaps="false"
            android:textColor="@color/button_onSecondary"
            app:backgroundTint="@color/button_secondary"
            app:cornerRadius="@dimen/radius_lg"
            app:layout_constraintTop_toBottomOf="@id/loginButton" />

        <!-- Create account -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/createAccountButton"
            style="@style/Body_SM.Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="42dp"
            android:elevation="0dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:text="@string/create_a_new_account"
            android:textAllCaps="false"
            android:textColor="@color/button_onSecondary"
            app:backgroundTint="@color/button_secondary"
            app:cornerRadius="@dimen/radius_lg"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>