<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <variable
            name="item"
            type="com.karrar.movieapp.ui.category.uiState.GenreUIState" />
        <variable
            name="listener"
            type="com.karrar.movieapp.ui.category.CategoryInteractionListener" />
    </data>

    <com.google.android.material.chip.Chip
        android:id="@+id/chip_genre"
        style="@style/Widget.MaterialComponents.Chip.Choice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@{item.genreName}"
        android:checkable="true"
        android:onClick="@{() -> listener.onClickCategory(item.genreID)}"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"/>
</layout>