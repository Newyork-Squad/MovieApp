<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="item"
            type="com.karrar.movieapp.ui.search.mediaSearchUIState.MediaUIState" />
        <variable
            name="listener"
            type="com.karrar.movieapp.ui.search.adapters.MediaSearchInteractionListener" />

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="236dp"
        android:layout_marginHorizontal="@dimen/spacing_small"
        android:layout_marginBottom="@dimen/spacing_medium">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/image_movie"
            android:layout_width="match_parent"
            android:layout_height="208dp"
            android:scaleType="centerCrop"
            android:onClick="@{() -> listener.onClickMediaResult(item)}"
            app:mediaPoster="@{item.mediaImage}"
            app:shapeAppearanceOverlay="@style/CardCorners.Large"
            tools:src="@drawable/test" />

        <TextView
            android:id="@+id/text_rate_movie"
            style="@style/Label_MD.Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="@dimen/spacing_small"
            android:layout_marginEnd="@dimen/spacing_small"
            android:background="@drawable/media_rate_text_bg"
            android:drawablePadding="4dp"
            android:paddingStart="@dimen/spacing_small"
            android:paddingTop="@dimen/spacing_too_small"
            android:paddingEnd="@dimen/spacing_xSmall"
            android:paddingBottom="@dimen/spacing_too_small"
            android:text='@{item.mediaVoteAverage}'
            android:textColor="@color/shade_primary"
            app:drawableEndCompat="@drawable/ic_star"
            tools:text="8.4" />

        <TextView
            android:id="@+id/text_title_movie"
            style="@style/Label_MD.Medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:ellipsize="end"
            android:maxLines="1"
            android:singleLine="true"
            android:text="@{item.mediaName}"
            android:textColor="@color/shade_secondary"
            android:textSize="@dimen/text_body_md"
            tools:text="The Mandalorian" />

    </RelativeLayout>
</layout>
