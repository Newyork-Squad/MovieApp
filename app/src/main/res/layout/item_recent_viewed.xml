<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="listener"
            type="com.karrar.movieapp.ui.search.adapters.RecentViewedInteractionListener" />

        <variable
            name="item"
            type="com.karrar.movieapp.ui.search.mediaSearchUIState.RecentMovieViewedUiState" />
    </data>

    <RelativeLayout
        android:layout_width="136dp"
        android:layout_height="208dp"
        android:layout_marginHorizontal="@dimen/spacing_small"
        android:layout_marginBottom="@dimen/spacing_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="match_parent"
            android:layout_height="182dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:onClick="@{ () -> listener.onClickRecentViewed(item)}"
            android:scaleType="centerCrop"
            app:mediaPoster="@{item.mediaImage}"
            tools:src="@drawable/test"
            app:shapeAppearanceOverlay="@style/CardCorners.Large" />

        <TextView
            style="@style/Label_MD.Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="@dimen/spacing_small"
            android:layout_marginEnd="@dimen/spacing_small"
            android:background="@drawable/media_rate_text_bg"
            android:drawablePadding="4dp"
            android:paddingStart="@dimen/spacing_small"
            android:paddingTop="@dimen/spacing_too_small"
            android:paddingEnd="@dimen/spacing_xSmall"
            android:paddingBottom="@dimen/spacing_too_small"
            android:text="@{item.mediaRate}"
            android:textColor="@color/shade_primary"
            app:drawableEndCompat="@drawable/ic_star" />

        <TextView
            style="@style/Label_MD.Medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:text="@{item.mediaName}"
            android:textColor="@color/shade_secondary"
            android:textSize="@dimen/text_body_md"
            android:singleLine="true"
            android:ellipsize="end"
            android:maxLines="1"/>

    </RelativeLayout>

</layout>
