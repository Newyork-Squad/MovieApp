<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="listener"
            type="com.karrar.movieapp.ui.movieDetails.DetailInteractionListener" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/reviews_comment"
            style="@style/Title.SM"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/top_reviews"
            android:textColor="@color/shade_primary"
            android:textFontWeight="500"
            android:layout_marginTop="24dp"
            android:layout_marginStart="16dp"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/show_more"
            style="@style/Body_MD.Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/show_more"
            android:textColor="@color/brand_primary"
            android:textFontWeight="500"
            android:onClick="@{() -> listener.onClickViewReviews()}"
            android:textSize="14sp"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="@id/reviews_comment"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/reviews_comment" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>