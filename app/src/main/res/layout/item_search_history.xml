<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="item"
            type="com.karrar.movieapp.ui.search.mediaSearchUIState.SearchHistoryUIState" />

        <variable
            name="listener"
            type="com.karrar.movieapp.ui.search.adapters.SearchHistoryInteractionListener" />

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/text_search_history"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            tools:text="Star Wars"
            android:text="@{item.name}"
            style="@style/Body_SM.Medium"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_weight="1"
            android:paddingTop="@dimen/spacing_normal"
            android:paddingBottom="@dimen/spacing_normal"
            app:drawableStartCompat="@drawable/outline_history"
            android:textColor="@color/shade_secondary"
            android:drawablePadding="6dp"
            android:onClick="@{() -> listener.onClickSearchHistory(item.name)}"/>
        <ImageView
            android:id="@+id/iv_clear_search_query"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/outline_close"
            android:paddingStart="@dimen/spacing_small"
            android:paddingTop="@dimen/spacing_normal"
            android:paddingEnd="@dimen/spacing_small"
            android:paddingBottom="@dimen/spacing_normal"
            android:onClick="@{() -> listener.onClickDeleteSearchHistoryItem(item)}"
            />

    </LinearLayout>

</layout>