<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="listener"
            type="com.karrar.movieapp.ui.search.adapters.SearchSuggestedInteractionListener" />
        <variable
            name="item"
            type="com.karrar.movieapp.ui.search.mediaSearchUIState.SearchKeywordUIState" />

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/text_search_history"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:drawableEndRes="@{@drawable/outline_arrow_left_up}"
            app:drawableStartByHistory="@{item.isFromHistory}"
            tools:text="Star Wars"
            android:text="@{item.keyword}"
            style="@style/Body_SM.Medium"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_weight="1"
            android:paddingTop="@dimen/spacing_normal"
            android:paddingBottom="@dimen/spacing_normal"
            android:textColor="@color/shade_secondary"
            android:drawablePadding="6dp"
            android:onClick="@{() -> listener.onClickSearchSuggested(item.keyword)}"/>

    </LinearLayout>

</layout>