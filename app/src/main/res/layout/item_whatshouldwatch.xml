<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    >
    <data>
    <variable
        name="listener"
        type="com.karrar.movieapp.ui.home.adapter.WhatShouldWatchListener" />
    </data>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_medium"
        android:layout_marginVertical="@dimen/spacing_medium"
        android:orientation="vertical"
        >
        <TextView
            android:id="@+id/should_watch_title"
            android:layout_width="match_parent"
            android:layout_height="22dp"
            style="@style/Title.SM"
            android:text="@string/what_should_i_watch"
            android:textColor="@color/shade_primary"

            />

         <androidx.constraintlayout.widget.ConstraintLayout
             android:layout_width="match_parent"
             android:layout_height="80dp"
             android:layout_gravity="center"
             android:background="@drawable/background_cast_item"
             android:layout_marginTop="@dimen/spacing_medium_small"
             android:layout_marginBottom="@dimen/spacing_medium"
             >
             <androidx.cardview.widget.CardView
                 android:id="@+id/img_whatshouldwatch"
                 android:layout_width="48dp"
                 android:layout_height="48dp"
                 android:backgroundTint="@color/shade_quinary"
                 app:cardCornerRadius="@dimen/radius_full"
                 app:cardElevation="@null"
                 android:layout_marginStart="16dp"
                 app:layout_constraintTop_toTopOf="parent"
                 app:layout_constraintBottom_toBottomOf="parent"
                 app:layout_constraintStart_toStartOf="parent"
               >

                 <ImageView
                     android:layout_width="24dp"
                     android:layout_height="24dp"
                     android:layout_gravity="center"
                     android:contentDescription="what should watch"
                     android:src="@drawable/outline_magic_stick"
                     app:tint="@color/brand_primary" />
             </androidx.cardview.widget.CardView>
             
             <TextView
                 android:id="@+id/tv_shoose"
                 style="@style/Title.SM"
                 android:layout_width="0dp"
                 android:layout_height="22dp"
                 android:layout_marginStart="@dimen/spacing_medium_small"
                 android:layout_marginTop="11dp"
                 android:text="@string/let_us_choose_for_you"
                 android:textColor="@color/shade_primary"
                 app:layout_constraintStart_toEndOf="@id/img_whatshouldwatch"
                 app:layout_constraintTop_toTopOf="parent"

                 />
              <TextView
                  android:id="@+id/tv_shoose_description"
                  android:layout_width="208dp"
                  android:layout_height="0dp"
                  android:layout_marginTop="@dimen/spacing_too_small"
                  android:layout_marginBottom="11dp"
                  style="@style/Body_MD.Medium"
                  android:lines="2"
                  android:textSize="12sp"
                  android:textColor="@color/shade_secondary"
                  android:text="@string/we_ll_help_you_skip_the_scroll_and_go_straight_to_the_good_stuff"
                   app:layout_constraintStart_toStartOf="@id/tv_shoose"
                  app:layout_constraintTop_toBottomOf="@id/tv_shoose"
                  app:layout_constraintBottom_toBottomOf="parent"

                  />
             
             
             <ImageButton
                 android:id="@+id/go_to_match"
                 android:layout_width="20dp"
                 android:layout_height="20dp"
                 android:layout_marginStart="12dp"
                 android:layout_marginEnd="@dimen/spacing_small"
                 android:onClick="@{()->listener.onClickWhatShouldWatch()}"
                 android:src="@drawable/outline_alt_arrow_right"
                 android:backgroundTint="@color/background_card"
                 android:background="@color/background_card"
                 app:layout_constraintTop_toTopOf="parent"
                 app:layout_constraintEnd_toEndOf="parent"
                 app:layout_constraintBottom_toBottomOf="parent"
                 app:layout_constraintStart_toEndOf="@id/tv_shoose_description"

                 />
             


         </androidx.constraintlayout.widget.ConstraintLayout>
        
        
        
        
        
        
    </LinearLayout>

</layout>